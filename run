#!/usr/bin/env node

const eight_queens = require("./src/8queens.js");
const board_size = 5;

const solutions = eight_queens.find_all_solutions(board_size);

solutions
    .map(board => eight_queens.board_to_string(board, board_size))
    .forEach(s => console.log(s));

console.log(`Found ${solutions.length} solutions`);
